{
  "name": "procrasticode",
  "displayName": "ProcrastiCode",
  "description": "Your developer break-time companion — jokes, trivia, animal pics, fun facts, news, PDF/Word viewer & Claude AI chat right in VS Code",
  "version": "0.0.2",
  "publisher": "samuel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "procrasticode.openDashboard",
        "title": "ProcrastiCode: Open Dashboard",
        "icon": "$(smiley)"
      },
      {
        "command": "procrasticode.randomJoke",
        "title": "ProcrastiCode: Random Joke"
      },
      {
        "command": "procrasticode.refreshJokes",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "procrasticode.refreshNews",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "procrasticode.openPdf",
        "title": "ProcrastiCode: Open PDF"
      },
      {
        "command": "procrasticode.openDocx",
        "title": "ProcrastiCode: Open Word Document"
      },
      {
        "command": "procrasticode.openChat",
        "title": "ProcrastiCode: Chat with Claude"
      },
      {
        "command": "procrasticode.setClaudeApiKey",
        "title": "ProcrastiCode: Set Claude API Key"
      },
      {
        "command": "procrasticode.xkcdRandom",
        "title": "ProcrastiCode: Random XKCD Comic"
      },
      {
        "command": "procrasticode.xkcdLatest",
        "title": "ProcrastiCode: Latest XKCD Comic"
      },
      {
        "command": "procrasticode.refreshTools",
        "title": "Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "procrasticode",
          "title": "ProcrastiCode",
          "icon": "media/processor-icon.svg"
        }
      ]
    },
    "views": {
      "procrasticode": [
        {
          "id": "procrasticodeJokes",
          "name": "Jokes & Facts"
        },
        {
          "id": "procrasticodeNews",
          "name": "Reddit Feed"
        },
        {
          "id": "procrasticodeTools",
          "name": "Tools",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "ProcrastiCode",
      "properties": {
        "procrasticode.claudeModel": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Claude model to use for chat. Options: claude-sonnet-4-20250514, claude-haiku-4-5-20251001, claude-opus-4-20250514"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "procrasticode.openDashboard",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "procrasticode.refreshJokes",
          "when": "view == procrasticodeJokes",
          "group": "navigation"
        },
        {
          "command": "procrasticode.refreshNews",
          "when": "view == procrasticodeNews",
          "group": "navigation"
        },
        {
          "command": "procrasticode.refreshTools",
          "when": "view == procrasticodeTools",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "procrasticode.openPdf",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        },
        {
          "command": "procrasticode.openDocx",
          "when": "resourceExtname == .docx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "compile:check": "tsc -p ./ --noEmit"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}
